{
  "manifest_version": 3,
  "name": "M7 Video Companion",
  "version": "1.0.0",
  "description": "Companheiro do MoviePy Studio para criação e edição de vídeos individuais na fila.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_icon": "icons/icon-128.png",
    "default_title": "Abrir Companheiro de Vídeos"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  }
}
