{
  "manifest_version": 3,
  "name": "MoviePy Ranking Companion",
  "version": "1.0.0",
  "description": "Auxiliar do MoviePy Studio para capturar vídeos do YouTube e adicioná-los diretamente aos rankings em tempo real.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "sidePanel", "scripting", "activeTab", "tabs"],
  "host_permissions": ["*://localhost/*", "https://*.youtube.com/*", "https://youtu.be/*"],
  "action": {
    "default_title": "Abrir MoviePy Companion",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  }
}
